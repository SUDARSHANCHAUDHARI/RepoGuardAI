{
  "name": "repoguard-ai",
  "version": "0.1.0",
  "description": "Tool-independent repository auditing framework that guides coding agents to review any repo for bugs, security, API and rate-limiting issues, dependency risk, and missing tests.",
  "type": "module",
  "bin": {
    "repoguard": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "prompts",
    "adapters",
    "rules",
    "schemas",
    "templates",
    "repoguard.config.example.yaml",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "CODEX.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "security",
    "audit",
    "code-review",
    "static-analysis",
    "ai-agents",
    "cli"
  ],
  "license": "MIT",
  "author": "Sudarshan Chaudhari (SudarshanTechLabs)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SUDARSHANCHAUDHARI/RepoGuardAI.git"
  },
  "homepage": "https://github.com/SUDARSHANCHAUDHARI/RepoGuardAI#readme",
  "bugs": {
    "url": "https://github.com/SUDARSHANCHAUDHARI/RepoGuardAI/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
